
CREATE TABLE users (
    id            UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    full_name     VARCHAR(150) NOT NULL,
    email         VARCHAR(150) UNIQUE NOT NULL,
    password_hash TEXT        NOT NULL,
    role          VARCHAR(20) NOT NULL CHECK (role IN ('admin', 'instructor', 'student')),
    is_active     BOOLEAN     NOT NULL DEFAULT TRUE,
    created_at    TIMESTAMP   NOT NULL DEFAULT NOW(),
    updated_at    TIMESTAMP   NOT NULL DEFAULT NOW()
);

CREATE TABLE student_profiles (
    id           UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id      UUID        NOT NULL UNIQUE REFERENCES users(id) ON DELETE CASCADE,
    department   VARCHAR(100),
    year         SMALLINT    CHECK (year BETWEEN 1 AND 6),
    interests    TEXT,
    github_url   VARCHAR(255),
    linkedin_url VARCHAR(255),
    bio          TEXT,
    created_at   TIMESTAMP   NOT NULL DEFAULT NOW(),
    updated_at   TIMESTAMP   NOT NULL DEFAULT NOW()
);

CREATE TABLE student_skills (
    id                 UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    student_profile_id UUID        NOT NULL REFERENCES student_profiles(id) ON DELETE CASCADE,
    skill_tag          VARCHAR(100) NOT NULL,
    UNIQUE (student_profile_id, skill_tag)
);

CREATE TABLE instructor_profiles (
    id                          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id                     UUID        NOT NULL UNIQUE REFERENCES users(id) ON DELETE CASCADE,
    department                  VARCHAR(100),
    academic_title              VARCHAR(100),
    areas_of_expertise          TEXT,
    research_interests          TEXT,
    supervised_project_types    TEXT,       -- free text: e.g. "TÜBİTAK, Teknofest"
    available_for_advising      BOOLEAN     NOT NULL DEFAULT TRUE,
);

-- ============================================================
-- 5. PROJECT CATEGORIES
--    Managed by Admin. Default: Course Project,
--    TÜBİTAK Student Project, Teknofest Student Project
-- ============================================================
CREATE TABLE project_categories (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    name        VARCHAR(150) NOT NULL UNIQUE,
    description TEXT,
    is_default  BOOLEAN     NOT NULL DEFAULT FALSE,
);

