-- ============================================================
-- 6. PROJECTS
--    Created by students. Linked to a category and optional advisor.
-- ============================================================
CREATE TABLE projects (
    id                UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    owner_id          UUID        NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    category_id       UUID        NOT NULL REFERENCES project_categories(id) ON DELETE RESTRICT,
    advisor_id        UUID        REFERENCES instructor_profiles(id) ON DELETE SET NULL,
    title             VARCHAR(255) NOT NULL,
    description       TEXT,
    team_size_needed  SMALLINT    CHECK (team_size_needed > 0),
    advisor_assigned  BOOLEAN     NOT NULL DEFAULT FALSE,
    status            VARCHAR(20) NOT NULL DEFAULT 'open'
                                  CHECK (status IN ('open', 'closed', 'completed')),
);

-- ============================================================
-- 7. PROJECT ROLES NEEDED
--    Roles a project owner is looking for (e.g. Frontend, Backend)
-- ============================================================
CREATE TABLE project_roles_needed (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    project_id  UUID        NOT NULL REFERENCES projects(id) ON DELETE CASCADE,
    role_name   VARCHAR(100) NOT NULL,
    UNIQUE (project_id, role_name)
);

-- ============================================================
-- 8. PROJECT SKILLS REQUIRED
--    Skills required for a project (tag-based)
-- ============================================================
CREATE TABLE project_skills_required (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    project_id  UUID        NOT NULL REFERENCES projects(id) ON DELETE CASCADE,
    skill_tag   VARCHAR(100) NOT NULL,
    UNIQUE (project_id, skill_tag)
);

-- ============================================================
-- 9. PROJECT APPLICATIONS
--    Students apply to open projects; owner accepts or rejects
-- ============================================================
CREATE TABLE project_applications (
    id           UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    project_id   UUID        NOT NULL REFERENCES projects(id) ON DELETE CASCADE,
    applicant_id UUID        NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    status       VARCHAR(20) NOT NULL DEFAULT 'pending'
                             CHECK (status IN ('pending', 'accepted', 'rejected')),
    UNIQUE (project_id, applicant_id)       -- one application per student per project
);

-- ============================================================
-- 10. TEAM MEMBERSHIPS
--     Students who have been accepted onto a project team
-- ============================================================
CREATE TABLE team_memberships (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    project_id  UUID        NOT NULL REFERENCES projects(id) ON DELETE CASCADE,
    student_id  UUID        NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    role        VARCHAR(100),               -- the role they fill on the team
    UNIQUE (project_id, student_id)
);

-- ============================================================
-- 11. ADVISOR REQUESTS
--     Students on TÜBİTAK / Teknofest projects request advisors
-- ============================================================
CREATE TABLE advisor_requests (
    id            UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    project_id    UUID        NOT NULL REFERENCES projects(id) ON DELETE CASCADE,
    student_id    UUID        NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    instructor_id UUID        NOT NULL REFERENCES instructor_profiles(id) ON DELETE CASCADE,
    status        VARCHAR(20) NOT NULL DEFAULT 'pending'
                              CHECK (status IN ('pending', 'accepted', 'rejected')),
    UNIQUE (project_id, instructor_id)      -- one request per project per instructor
);

-- ============================================================
-- 12. ANNOUNCEMENTS
--     Published by Admin; linked to a project category
-- ============================================================
CREATE TABLE announcements (
    id            UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    admin_id      UUID        NOT NULL REFERENCES users(id) ON DELETE CASCADE,
    category_id   UUID        REFERENCES project_categories(id) ON DELETE SET NULL,
    title         VARCHAR(255) NOT NULL,
    description   TEXT,
    deadline_date DATE,
);

-- ============================================================
-- INDEXES — speed up the most common look-ups
-- ============================================================

-- Users
CREATE INDEX idx_users_role       ON users(role);
CREATE INDEX idx_users_email      ON users(email);

-- Student profiles
CREATE INDEX idx_student_user     ON student_profiles(user_id);
CREATE INDEX idx_student_dept     ON student_profiles(department);

-- Student skills
CREATE INDEX idx_student_skill    ON student_skills(student_profile_id);
CREATE INDEX idx_skill_tag        ON student_skills(skill_tag);

-- Instructor profiles
CREATE INDEX idx_instructor_user  ON instructor_profiles(user_id);
CREATE INDEX idx_instructor_dept  ON instructor_profiles(department);
CREATE INDEX idx_instructor_avail ON instructor_profiles(available_for_advising);

-- Projects
CREATE INDEX idx_project_owner    ON projects(owner_id);
CREATE INDEX idx_project_category ON projects(category_id);
CREATE INDEX idx_project_advisor  ON projects(advisor_id);
CREATE INDEX idx_project_status   ON projects(status);

-- Applications
CREATE INDEX idx_app_project      ON project_applications(project_id);
CREATE INDEX idx_app_applicant    ON project_applications(applicant_id);
CREATE INDEX idx_app_status       ON project_applications(status);

-- Team memberships
CREATE INDEX idx_member_project   ON team_memberships(project_id);
CREATE INDEX idx_member_student   ON team_memberships(student_id);

-- Advisor requests
CREATE INDEX idx_adv_req_project  ON advisor_requests(project_id);
CREATE INDEX idx_adv_req_student  ON advisor_requests(student_id);
CREATE INDEX idx_adv_req_instr    ON advisor_requests(instructor_id);
CREATE INDEX idx_adv_req_status   ON advisor_requests(status);

-- Announcements
CREATE INDEX idx_ann_category     ON announcements(category_id);
CREATE INDEX idx_ann_deadline     ON announcements(deadline_date);

-- ============================================================
-- AUTO-UPDATE updated_at via trigger function
-- ============================================================
CREATE OR REPLACE FUNCTION set_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = NOW();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_users_updated
    BEFORE UPDATE ON users
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER trg_student_profiles_updated
    BEFORE UPDATE ON student_profiles
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER trg_instructor_profiles_updated
    BEFORE UPDATE ON instructor_profiles
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER trg_projects_updated
    BEFORE UPDATE ON projects
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

CREATE TRIGGER trg_announcements_updated
    BEFORE UPDATE ON announcements
    FOR EACH ROW EXECUTE FUNCTION set_updated_at();

